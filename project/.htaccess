Options -Indexes +FollowSymLinks +MultiViews
Require all granted

# Chỉ định trang 404 tùy chỉnh
ErrorDocument 404 /static/404.php

RewriteEngine On
# RewriteBase intentionally omitted for portability between local '/project/' and production '/'

# Rewrite root URL (/) to /static/home.php
RewriteRule ^$ static/home.php [L]

# Sitemap endpoint
RewriteRule ^sitemap\.xml$ static/sitemap.php [L,NC]

# Stable same-origin favicon endpoint
RewriteRule ^favicon\.ico$ static/favicon.php [L,NC]

# Prevent directory listing UX for admin path by routing to dashboard/login flow
RewriteRule ^admin/?$ admin/dashboard.php [L,NC]

# Legacy post query URL -> .html route (SEO 301)
RewriteCond %{REQUEST_URI} ^/(?:static/)?view_post\.php$ [NC]
RewriteCond %{QUERY_STRING} (^|&)post_id=([0-9]+)(&|$) [NC]
RewriteRule ^(?:static/)?view_post\.php$ static/post_redirect.php?post_id=%2 [L,NC]

# Clean routes for static pages without .php extension
RewriteRule ^(home|posts|category|all_photos|search|contact|login|register|forgot_pass|reset_pass|update|new_post|user_likes|user_comments|author_posts|menu|introduce)/?$ static/$1.php [L,QSA,NC]

RewriteRule ^post/([^/.]+)/?$ /post/$1.html [R=301,L,NC]

# SEO post route: /post/my-title-123.html
RewriteRule ^post/([^/]+)\.html$ static/view_post.php?slug=$1 [L,QSA,NC]

# Community post detail route: /community/p/my-post-123
RewriteRule ^community/p/([^/]+)/?$ static/community_post.php?slug=$1 [L,QSA,NC]

# Community public profile route: /community/u/username-123
RewriteRule ^community/u/([^/]+)/?$ static/community_profile.php?user=$1 [L,QSA,NC]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ static/$1 [L]

# Fallback: unknown route -> static 404 page
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ static/404.php [L]